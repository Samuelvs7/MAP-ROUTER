PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/maprouter?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# AI provider selection: openai | gemini | openrouter
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
AI_TIMEOUT_MS=15000

ORS_API_KEY=your_openrouteservice_api_key_here
WEATHER_API_KEY=your_openweathermap_api_key_here
SERP_API_KEY=your_serpapi_key_here
MAPILLARY_TOKEN=your_mapillary_token_here
ML_PREDICT_URL=http://localhost:5001/predict

# Optional SMTP settings for sending real verification emails.
# If these are omitted, the backend falls back to preview links in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AI Route Planner <no-reply@example.com>
