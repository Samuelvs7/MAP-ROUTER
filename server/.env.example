PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smartrouter?retryWrites=true&w=majority
ORS_API_KEY=your_openrouteservice_api_key_here
WEATHER_API_KEY=your_openweathermap_api_key_here
