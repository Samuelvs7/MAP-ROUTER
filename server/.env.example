SERP_API_KEY=your_serpapi_key_here
MAPILLARY_TOKEN=your_mapillary_token_here
ML_PREDICT_URL=http://localhost:5001/predict
JWT_SECRET=replace_with_a_secure_secret
NODE_ENV=development
